{
  "name": "n8n-nodes-api-cmdeb",
  "displayName": "API CMDEB 2.0 - SEDUC - CE",
  "version": "1.0.9",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GUIKAR741/n8n-nodes-api-cmdeb.git"
  },
  "homepage": "https://github.com/GUIKAR741/n8n-nodes-api-cmdeb#readme",
  "bugs": {
    "url": "https://github.com/GUIKAR741/n8n-nodes-api-cmdeb/issues"
  },
  "description": "Node n8n personalizado para integração e autenticação nativa com na API CMDEB 2.0 SEDUC - CE.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ApiCmdeb2.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ApiCmdeb2/ApiCmdeb2.node.js"
    ]
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && gulp build:assets",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lint:fix": "eslint nodes credentials package.json --fix",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "API SGP 2.0",
    "API CMDEB 2.0",
    "MEC"
  ],
  "author": "Guilherme Nepomuceno de Carvalho<guilhermenepomuceno46@gmail.com>",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/node-forge": "^1.3.14",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "axios": "^1.17.0",
    "eslint": "^9.35.0",
    "gulp": "^5.0.1",
    "n8n-workflow": "^1.120.17",
    "prettier": "^3.8.4",
    "typescript": "^5.5.4"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}
